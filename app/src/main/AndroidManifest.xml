<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Core network permissions for Firebase realtime data access -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TravelEase">

        <!-- Splash Launcher Screen (Premium fullscreen dark background overlay) -->
        <activity
            android:name=".view.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.TravelEase.FullScreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding (Premium fullscreen paginated user onboarding slides) -->
        <activity
            android:name=".view.OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.TravelEase.FullScreen" />

        <!-- Login / Registration Form Activities -->
        <activity
            android:name=".view.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".view.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".view.ForgotPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".view.EditProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Main Dashboard View Container (Floating Bottom Nav and core Fragments) -->
        <activity
            android:name=".view.MainActivity"
            android:exported="false" />

        <!-- Vehicle specifications Bento details and visual grids -->
        <activity
            android:name=".view.VehicleDetailActivity"
            android:exported="false" />

        <!-- Booking details, range selection calendar and pricing checkout components -->
        <activity
            android:name=".view.BookingActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Admin consoles and custom car upload console forms -->
        <activity
            android:name=".view.AdminDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".view.AdminPanelActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".view.AddVehicleActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground">

    <!-- ViewPager2 for sliding pages -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/onboardingViewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomContainer" />

    <!-- Bottom Controls Area -->
    <RelativeLayout
        android:id="@+id/bottomContainer"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_alignParentBottom="true"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Dot Indicator (We will use a simple custom LinearLayout for dot indicators dynamically, or TabLayout) -->
        <LinearLayout
            android:id="@+id/dotsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center" />

        <!-- Navigation Buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Skip Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSkip"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_btn_skip"
                android:textColor="?android:attr/textColorSecondary"
                android:textStyle="bold"
                android:layout_marginEnd="12dp" />

            <!-- Next / Get Started Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_btn_next"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                android:backgroundTint="@color/primary_blue"
                android:textColor="@color/white"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>

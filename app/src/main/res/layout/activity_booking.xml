<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground">

    <!-- Top Toolbar Header -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/toolbarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="?attr/colorSurface">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Back Arrow -->
            <ImageView
                android:id="@+id/btnBookingBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:layout_centerVertical="true"
                app:tint="?android:attr/textColorPrimary"
                android:contentDescription="@null"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Booking Checkout"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_centerInParent="true" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Content scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbarLayout"
        android:layout_above="@id/bottomConfirmLayout"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card 1: Selected Vehicle Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurface"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selected Vehicle"
                        android:textSize="12sp"
                        android:textColor="@color/primary_blue"
                        android:textStyle="bold"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/textVehicleName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mercedes-Benz S-Class"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/textVehiclePricePerDay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹ 0 / km"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="4dp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: Date, Time & Total Days -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurface"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ride Scheduling"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="16dp" />

                    <!-- Pickup date Selector -->
                    <RelativeLayout
                        android:id="@+id/btnSelectPickupDate"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/edit_text_bg"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pickup Date"
                            android:textSize="11sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:layout_alignParentTop="true"
                            android:layout_marginTop="6dp" />

                        <TextView
                            android:id="@+id/textPickupDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Date"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="8dp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_booking"
                            app:tint="@color/primary_blue"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:contentDescription="@null" />
                    </RelativeLayout>

                    <!-- Pickup Time Selector -->
                    <RelativeLayout
                        android:id="@+id/btnSelectPickupTime"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/edit_text_bg"
                        android:layout_marginTop="12dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pickup Time"
                            android:textSize="11sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:layout_alignParentTop="true"
                            android:layout_marginTop="6dp" />

                        <TextView
                            android:id="@+id/textPickupTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Time"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="8dp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_time"
                            app:tint="@color/primary_blue"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:contentDescription="@null" />
                    </RelativeLayout>

                    <!-- Total Days Picker (Increment/Decrement Counter) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="20dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Rental Days"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/edit_text_bg"
                            android:padding="4dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnDecrementDays"
                                style="@style/Widget.MaterialComponents.Button.Icon"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:padding="0dp"
                                app:icon="@drawable/ic_minus"
                                app:iconSize="16dp"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp"
                                app:iconTint="@color/primary_blue"
                                app:backgroundTint="@color/primary_blue_light"
                                app:cornerRadius="8dp" />

                            <TextView
                                android:id="@+id/textDaysCount"
                                android:layout_width="50dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="1"
                                android:textColor="?android:attr/textColorPrimary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnIncrementDays"
                                style="@style/Widget.MaterialComponents.Button.Icon"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:padding="0dp"
                                app:icon="@drawable/ic_add"
                                app:iconSize="16dp"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp"
                                app:iconTint="@color/primary_blue"
                                app:backgroundTint="@color/primary_blue_light"
                                app:cornerRadius="8dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 3: Important Default Note Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/accent_orange"
                app:cardBackgroundColor="@color/accent_orange_light"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/accent_orange"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@null" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Booking Policy Note"
                            android:textSize="12sp"
                            android:textColor="@color/accent_orange"
                            android:textStyle="bold"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/bookingNoteText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Night charges, driver food, and toll tax are separate."
                            android:textSize="14sp"
                            android:textColor="@color/text_primary_light"
                            android:textStyle="italic"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 4: Pickup & Dropoff Address & Special Request -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurface"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ride Details"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="16dp" />

                    <!-- Pickup Address -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/pickupAddressLayout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxStrokeColor="@color/primary_blue"
                        app:hintTextColor="@color/primary_blue"
                        app:startIconDrawable="@drawable/ic_location"
                        app:startIconTint="@color/primary_blue">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editPickupLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Pickup Location / Address"
                            android:inputType="textPostalAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Dropoff Address -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/dropoffAddressLayout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxStrokeColor="@color/primary_blue"
                        app:hintTextColor="@color/primary_blue"
                        app:startIconDrawable="@drawable/ic_location"
                        app:startIconTint="@color/primary_blue">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editDropoffLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Dropoff Location / Address"
                            android:inputType="textPostalAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Optional Note / Special Request -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/specialRequestLayout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxStrokeColor="@color/primary_blue"
                        app:hintTextColor="@color/primary_blue"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="@color/primary_blue">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editSpecialRequest"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Optional Note / Special Requests"
                            android:inputType="textMultiLine"
                            android:minLines="1"
                            android:maxLines="3" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Confirm Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomConfirmLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        app:cardCornerRadius="0dp"
        app:cardElevation="12dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Final Total Price"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textStyle="bold"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/textTotalCost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 0"
                    android:textColor="@color/primary_blue"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmBooking"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Confirm Booking"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="14dp"
                android:backgroundTint="@color/primary_blue"
                android:textColor="@color/white"
                app:rippleColor="#40FFFFFF" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</RelativeLayout>

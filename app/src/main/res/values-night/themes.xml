<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Dark variant). -->
    <style name="Theme.TravelEase" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/bg_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="colorSecondaryVariant">@color/accent_orange</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Background and Surface colors -->
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/card_dark</item>
        
        <!-- Status bar and navigation bar styling -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <!-- Transparent status bar theme for Onboarding and Splash -->
    <style name="Theme.TravelEase.FullScreen" parent="Theme.TravelEase">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>